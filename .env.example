# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose which LLM backend to use:
#   groq  → Free tier, powered by Llama 3.3-70B  (used during development)
#   grok  → xAI's native Grok model, paid         (recommended for best quality)
LLM_PROVIDER=groq

# Groq API key — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Grok (xAI) API key — get one at https://console.x.ai
# Only required if LLM_PROVIDER=grok
GROK_API_KEY=your_grok_api_key_here

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# ── LightRAG ───────────────────────────────────────────────────────────────────
LIGHTRAG_WORKING_DIR=./lightrag_storage
